<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="wrap_content"
    android:orientation="vertical" android:padding="12dp">
    <TextView android:id="@+id/tv_category_name"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:textColor="@color/neon_cyan" android:textSize="13sp"
        android:textStyle="bold" android:letterSpacing="0.1" />
    <TextView android:id="@+id/tv_items_preview"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:textColor="@color/text_secondary" android:textSize="12sp"
        android:layout_marginTop="4dp" android:lineSpacingExtra="3dp" />
</LinearLayout>
