<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_deep_black">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp"
            android:paddingTop="20dp"
            android:paddingBottom="100dp">

            <!-- Title -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="UPLOAD REQUIREMENTS"
                android:textColor="@color/neon_cyan"
                android:textSize="11sp"
                android:letterSpacing="0.25"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Paste Requirement Text"
                android:textColor="@color/text_primary"
                android:textSize="24sp"
                android:textStyle="bold"
                android:layout_marginTop="4dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Intelligent parsing will auto-organize your requirements"
                android:textColor="@color/text_secondary"
                android:textSize="13sp"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="24dp" />

            <!-- Input box -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/bg_card"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:padding="12dp"
                        android:background="@color/bg_card_elevated">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="RAW INPUT"
                            android:textColor="@color/neon_cyan"
                            android:textSize="10sp"
                            android:letterSpacing="0.2" />

                        <TextView
                            android:id="@+id/tv_char_count"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0 chars"
                            android:textColor="@color/text_muted"
                            android:textSize="11sp" />

                        <TextView
                            android:id="@+id/btn_clear"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="CLEAR"
                            android:textColor="@color/status_overdue"
                            android:textSize="11sp"
                            android:letterSpacing="0.1"
                            android:layout_marginStart="12dp"
                            android:paddingStart="4dp"
                            android:paddingEnd="4dp" />
                    </LinearLayout>

                    <EditText
                        android:id="@+id/et_raw_input"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:minHeight="240dp"
                        android:gravity="top"
                        android:hint="@string/parse_hint"
                        android:textColorHint="@color/text_muted"
                        android:textColor="@color/text_primary"
                        android:textSize="14sp"
                        android:fontFamily="monospace"
                        android:background="@null"
                        android:padding="16dp"
                        android:inputType="textMultiLine|textCapSentences"
                        android:scrollbars="vertical" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Scan button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_parse"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="16dp"
                android:text="⬡  SCAN &amp; ANALYZE"
                android:textSize="15sp"
                android:letterSpacing="0.12"
                android:textStyle="bold"
                android:backgroundTint="@color/transparent"
                android:background="@drawable/bg_button_neon"
                android:textColor="@color/bg_deep_black" />

            <!-- Loading indicator -->
            <LinearLayout
                android:id="@+id/layout_loading"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_marginTop="16dp"
                android:visibility="gone">
                <ProgressBar
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:indeterminateTint="@color/neon_cyan" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ANALYZING REQUIREMENTS..."
                    android:textColor="@color/neon_cyan"
                    android:textSize="12sp"
                    android:letterSpacing="0.1"
                    android:layout_marginStart="10dp" />
            </LinearLayout>

            <!-- Parse results preview -->
            <LinearLayout
                android:id="@+id/layout_results"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone"
                android:layout_marginTop="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="10dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="PARSED RESULTS"
                        android:textColor="@color/status_completed"
                        android:textSize="11sp"
                        android:letterSpacing="0.2" />

                    <TextView
                        android:id="@+id/tv_parse_summary"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="2 categories • 12 items"
                        android:textColor="@color/text_secondary"
                        android:textSize="12sp" />
                </LinearLayout>

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rv_preview"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:overScrollMode="never"
                    android:nestedScrollingEnabled="false" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_deploy"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginTop="16dp"
                    android:text="⬡  DEPLOY MISSION"
                    android:textSize="15sp"
                    android:letterSpacing="0.12"
                    android:textStyle="bold"
                    android:backgroundTint="@color/transparent"
                    android:background="@drawable/bg_button_neon"
                    android:textColor="@color/bg_deep_black" />
            </LinearLayout>

            <!-- Error state -->
            <TextView
                android:id="@+id/tv_error"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/status_overdue"
                android:textSize="13sp"
                android:layout_marginTop="12dp"
                android:visibility="gone" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
