<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- Base cyberpunk dark theme -->
    <style name="Theme.ReqSync" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/neon_cyan</item>
        <item name="colorPrimaryVariant">@color/neon_cyan_dim</item>
        <item name="colorSecondary">@color/purple_glow</item>
        <item name="colorSecondaryVariant">@color/purple_dim</item>
        <item name="android:colorBackground">@color/bg_deep_black</item>
        <item name="colorSurface">@color/bg_card</item>
        <item name="colorError">@color/status_overdue</item>
        <item name="colorOnPrimary">@color/bg_deep_black</item>
        <item name="colorOnSecondary">@color/bg_deep_black</item>
        <item name="colorOnBackground">@color/text_primary</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="colorOnError">@color/text_primary</item>

        <!-- Window -->
        <item name="android:windowBackground">@color/bg_deep_black</item>
        <item name="android:statusBarColor">@color/bg_deep_black</item>
        <item name="android:navigationBarColor">@color/bg_deep_black</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowLightNavigationBar">false</item>

        <!-- Text -->
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>
        <item name="android:textColorHint">@color/text_muted</item>

        <!-- Shape -->
        <item name="shapeAppearanceSmallComponent">@style/ShapeSmall</item>
        <item name="shapeAppearanceMediumComponent">@style/ShapeMedium</item>
        <item name="shapeAppearanceLargeComponent">@style/ShapeLarge</item>

        <!-- Edit text cursor -->
        <item name="colorControlActivated">@color/neon_cyan</item>
        <item name="colorControlNormal">@color/text_muted</item>
    </style>

    <!-- Splash theme -->
    <style name="Theme.ReqSync.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/bg_deep_black</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_splash_logo</item>
        <item name="postSplashScreenTheme">@style/Theme.ReqSync</item>
    </style>

    <!-- Shapes -->
    <style name="ShapeSmall" parent="ShapeAppearance.MaterialComponents.SmallComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">8dp</item>
    </style>
    <style name="ShapeMedium" parent="ShapeAppearance.MaterialComponents.MediumComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">12dp</item>
    </style>
    <style name="ShapeLarge" parent="ShapeAppearance.MaterialComponents.LargeComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">16dp</item>
    </style>

    <!-- Card style -->
    <style name="CardStyle.Cyberpunk" parent="Widget.MaterialComponents.CardView">
        <item name="cardBackgroundColor">@color/bg_card</item>
        <item name="cardCornerRadius">12dp</item>
        <item name="cardElevation">0dp</item>
        <item name="strokeColor">@color/border_glow</item>
        <item name="strokeWidth">1dp</item>
    </style>

    <!-- Button: Primary neon -->
    <style name="Button.Neon" parent="Widget.MaterialComponents.Button">
        <item name="backgroundTint">@color/transparent</item>
        <item name="android:background">@drawable/bg_button_neon</item>
        <item name="android:textColor">@color/bg_deep_black</item>
        <item name="android:letterSpacing">0.12</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textAllCaps">true</item>
    </style>

    <!-- Button: Outlined -->
    <style name="Button.Outline" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="strokeColor">@color/neon_cyan</item>
        <item name="android:textColor">@color/neon_cyan</item>
        <item name="backgroundTint">@color/transparent</item>
        <item name="android:letterSpacing">0.10</item>
    </style>

    <!-- TextInput cyberpunk -->
    <style name="TextInput.Cyberpunk" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <item name="boxStrokeColor">@color/neon_cyan</item>
        <item name="boxStrokeWidth">1dp</item>
        <item name="hintTextColor">@color/neon_cyan</item>
        <item name="android:textColorHint">@color/text_muted</item>
        <item name="boxBackgroundColor">@color/bg_card</item>
        <item name="shapeAppearance">@style/ShapeMedium</item>
    </style>

    <!-- Chip neon -->
    <style name="Chip.Neon" parent="Widget.MaterialComponents.Chip.Filter">
        <item name="chipBackgroundColor">@drawable/selector_chip_bg</item>
        <item name="chipStrokeColor">@color/neon_cyan</item>
        <item name="chipStrokeWidth">1dp</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="checkedIconVisible">false</item>
    </style>

    <!-- Progress bar cyberpunk -->
    <style name="ProgressBar.Glow" parent="">
        <item name="android:progressTint">@color/neon_cyan</item>
        <item name="android:progressBackgroundTint">@color/bg_card</item>
    </style>

</resources>
